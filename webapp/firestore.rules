rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // App config — only app admins can write; any authenticated user can read
    match /app_config/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        request.auth.token.email in ['hrishikeshb@gmail.com', 'rohitbhagwat@gmail.com'];
    }

    // Users collection — each user can read/write their own doc
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Organizations — only allowed users can create; any authenticated user can read/update
    match /organizations/{orgId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        exists(/databases/$(database)/documents/app_config/allowed_users) &&
        request.auth.token.email in
          get(/databases/$(database)/documents/app_config/allowed_users).data.emails;
      allow update: if request.auth != null;
      allow delete: if request.auth != null &&
        request.auth.token.email in ['hrishikeshb@gmail.com', 'rohitbhagwat@gmail.com'];

      // Document types subcollection
      match /document_types/{typeId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }

      // Counters subcollection
      match /counters/{counterId} {
        allow read, write: if request.auth != null;
      }

      // Products/services subcollection
      match /products_services/{productId} {
        allow read, write: if request.auth != null;
      }
    }

    // Memberships — authenticated users can read; owners manage
    match /memberships/{membershipId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // Invitations — authenticated users can read/write
    match /invitations/{invitationId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null;
    }
  }
}
